{
  // See https://go.microsoft.com/fwlink/?LinkId=733558
  // for the documentation about the tasks.json format
  "version": "2.0.0",
  "tasks": [
    {
      "label": "Build xoptfoil2",
      "type": "shell",
      "command": "",
      "windows": {
        "command": "${workspaceFolder}\\build_windows.bat"
      },
      "options": {
        "cwd": "${workspaceFolder}"
      },
      "problemMatcher": [],
      "group": {
        "kind": "build",
        "isDefault": true
      }
    },
    {
      "label": "Build xoptfoil2 debug",
      "type": "shell",
      "command": "",
      "windows": {
        "command": "${workspaceFolder}\\build_windows_debug.bat"
      },
      "options": {
        "cwd": "${workspaceFolder}"
      },
      "problemMatcher": [],
      "group": "build"
    },
    {
      "label": "Generate Linter Mods",
      "type": "shell",
      "windows": {
        "command": "${workspaceFolder}\\.vscode\\generate_linter_mods.bat"
      },
      "problemMatcher": [],
      "presentation": {
        "echo": true,
        "reveal": "always",
        "panel": "shared"
      }
    },
  ]
}